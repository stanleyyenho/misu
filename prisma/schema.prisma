generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Contact {
  id                String               @id @default(cuid())
  userId            String
  firstName         String
  lastName          String?
  email             String?
  phone             String?
  avatarUrl         String?
  // Primary messaging delivery channel for this contact
  messagingPlatform String?              // sms | imessage | whatsapp | instagram | messenger
  // Context notes fed into AI message generation
  notes             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  schedule          CheckInSchedule?
  checkIns          CheckIn[]
  messageLogs       MessageLog[]
  groups            ContactGroupMember[]
  hangouts          Hangout[]

  @@index([userId])
}

model ContactGroup {
  id        String               @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime             @default(now())
  members   ContactGroupMember[]

  @@index([userId])
}

model ContactGroupMember {
  contactId String
  groupId   String
  contact   Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  group     ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([contactId, groupId])
}

model CheckInSchedule {
  id               String    @id @default(cuid())
  contactId        String    @unique
  contact          Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  frequencyDays    Int
  frequencyJitterDays Int @default(0)
  catchupFormats   String    // JSON array: ["zoom","facetime","in-person"]
  // AI generation config
  tone             String    @default("casual")  // casual | warm | formal | playful
  checkInType      String    @default("generic") // generic | hangout-prompt
  approveBeforeSend Boolean  @default(true)
  nextCheckIn      DateTime
  lastCheckIn      DateTime?
  isActive         Boolean   @default(true)
  // v2 hangout coordination
  hangoutType      String    @default("in-person") // in-person | digital
  cadenceMode      String    @default("prompt")    // prompt | perpetual | planned
  leadTimeDays     Int       @default(7)
  defaultHangout   String?   // JSON: { locationName, locationAddr, locationLat, locationLng, platform, meetingLink, time (HH:mm) }
  noteToFriend     String?   // static note included with every recurring hangout invite
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  hangoutInstances HangoutInstance[]
}

model CheckIn {
  id          String       @id @default(cuid())
  contactId   String
  contact     Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  scheduledAt DateTime
  completedAt DateTime?
  format      String?
  notes       String?
  status      String       @default("pending") // pending | completed | skipped
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  messageLog  MessageLog?
  hangout     Hangout?

  @@index([contactId, status])
  @@index([status, scheduledAt])
}

// Tracks every AI-generated message: draft, sent, or delivered
model MessageLog {
  id          String    @id @default(cuid())
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  checkInId   String?   @unique
  checkIn     CheckIn?  @relation(fields: [checkInId], references: [id], onDelete: SetNull)
  platform    String    // sms | imessage | whatsapp | instagram | messenger
  tone        String    // casual | warm | formal | playful
  message     String
  status      String    @default("draft") // draft | sent | delivered
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
}

model UserProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  firstName          String
  lastName           String   @default("")
  email              String   @default("")
  phone              String   @default("")
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model CalendarShare {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @default(cuid())
  label     String
  createdAt DateTime @default(now())
}

model NotificationSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  keys      String   // JSON: { p256dh, auth }
  createdAt DateTime @default(now())

  @@index([userId])
}

model Hangout {
  id            String            @id @default(cuid())
  userId        String
  contactId     String
  contact       Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  checkInId     String?           @unique
  checkIn       CheckIn?          @relation(fields: [checkInId], references: [id], onDelete: SetNull)
  type          String            // in-person | digital
  status        String            @default("draft") // draft | invited | confirmed | declined | counter | completed | skipped
  date          DateTime
  locationName  String?
  locationAddr  String?
  locationLat   Float?
  locationLng   Float?
  platform      String?           // zoom | facetime | google-meet | teams | other
  meetingLink   String?
  noteToFriend  String?
  calInviteSent Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  reminders     HangoutReminder[]
  instance      HangoutInstance?

  @@index([userId])
  @@index([userId, status, date])
}

model HangoutReminder {
  id        String   @id @default(cuid())
  hangoutId String
  hangout   Hangout  @relation(fields: [hangoutId], references: [id], onDelete: Cascade)
  sendAt    DateTime
  channel   String   // sms | push
  recipient String   // contact | user
  sentAt    DateTime?
  status    String   @default("scheduled") // scheduled | sent | failed
  createdAt DateTime @default(now())

  @@index([status, sendAt])
}

model HangoutInstance {
  id           String          @id @default(cuid())
  scheduleId   String
  schedule     CheckInSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  instanceNum  Int
  date         DateTime
  locationName String?
  locationAddr String?
  locationLat  Float?
  locationLng  Float?
  platform     String?
  meetingLink  String?
  hangoutId    String?         @unique
  hangout      Hangout?        @relation(fields: [hangoutId], references: [id], onDelete: SetNull)
  createdAt    DateTime        @default(now())

  @@unique([scheduleId, instanceNum])
  @@index([scheduleId, hangoutId])
}
